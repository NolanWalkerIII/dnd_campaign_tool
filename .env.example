# Copy this file to .env and fill in your actual key.
# .env is gitignored — never commit it to version control.

# Flask session signing key (REQUIRED)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate_a_random_hex_string_here

# Set to true ONLY on the production server (served over HTTPS).
# Leave unset or false for local/Docker development over HTTP.
COOKIE_SECURE=false

XAI_API_KEY=your_xai_api_key_here

# Twilio SMS (optional — enables SMS Play Mode)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567

# Discord Bot (optional — enables Discord integration)
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_client_id

# Claude API (optional — enables external API access for automation)
CLAUDE_API_KEY=generate_from_settings_page

# Database (optional — defaults to SQLite for local dev)
# Uncomment and set for PostgreSQL in production (also enable 'db' in docker-compose.yml)
# Ensure .env permissions are 600 on the server: chmod 600 .env
# DATABASE_URL=postgresql://quester:quester@db:5432/questerledger
